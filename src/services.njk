    <!-- ========== WHAT TO EXPECT TIMELINE ========== -->
    <section id="what-to-expect" class="py-16 md:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-sage-900 mb-4">What to Expect</h2>
          <div class="w-16 h-1 bg-sage-400 mx-auto rounded-full mb-6"></div>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">Your journey toward healing is simpler than you think. Here&rsquo;s how we get started.</p>
        </div>

        <div class="timeline-container">
          <!-- Step 1 -->
          <div class="timeline-step">
            <div class="timeline-number">1</div>
            <div class="timeline-content">
              <div class="timeline-icon bg-sky-100">
                <svg class="w-6 h-6 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-sage-800 mb-1">Free Phone Consultation</h3>
              <p class="text-sm text-gray-500 mb-2">15 minutes &bull; No obligation</p>
              <p class="text-gray-600 text-sm leading-relaxed">We&rsquo;ll have a brief, friendly chat so you can share what you&rsquo;re looking for and ask any questions. This helps us both see if we&rsquo;re a good fit.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="timeline-step">
            <div class="timeline-number">2</div>
            <div class="timeline-content">
              <div class="timeline-icon bg-warm-100">
                <svg class="w-6 h-6 text-warm-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-sage-800 mb-1">First Session</h3>
              <p class="text-sm text-gray-500 mb-2">50 minutes &bull; Getting to know each other</p>
              <p class="text-gray-600 text-sm leading-relaxed">No pressure &mdash; this is about getting comfortable. We&rsquo;ll talk about what brought you here, identify your stressors, and start building a personalized plan together.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="timeline-step">
            <div class="timeline-number">3</div>
            <div class="timeline-content">
              <div class="timeline-icon bg-sage-100">
                <svg class="w-6 h-6 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-sage-800 mb-1">Ongoing Sessions</h3>
              <p class="text-sm text-gray-500 mb-2">Weekly or as needed &bull; At your pace</p>
              <p class="text-gray-600 text-sm leading-relaxed">We&rsquo;ll meet regularly to work through challenges, build skills, and track your progress. Sessions are tailored to your unique needs and goals.</p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="timeline-step">
            <div class="timeline-number">4</div>
            <div class="timeline-content">
              <div class="timeline-icon bg-cream-200">
                <svg class="w-6 h-6 text-warm-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-sage-800 mb-1">Growth &amp; Progress</h3>
              <p class="text-sm text-gray-500 mb-2">Celebrate your wins</p>
              <p class="text-gray-600 text-sm leading-relaxed">As you develop new coping strategies and insights, you&rsquo;ll start to see meaningful changes in your relationships, mood, and daily life. We celebrate every step forward.</p>
            </div>
          </div>
        </div>

        <div class="text-center mt-10">
          <a href="/contact.html" class="inline-flex items-center gap-2 bg-sage-600 hover:bg-sage-700 text-white font-semibold px-8 py-4 rounded-full text-lg transition-all hover:shadow-lg">
