{% extends "base.njk" %}

{% block title %}Contact | Amanda Levy, LCSW | Therapist in Jackson, NJ{% endblock %}

{% block meta %}
  <meta name="description" content="Contact Amanda Levy, LCSW for a free 15-minute consultation. Located in Jackson, NJ. Phone, email, and online contact form available. In-person and telehealth sessions.">
  <meta name="robots" content="index, follow">

  <!-- Open Graph -->
  <meta property="og:title" content="Contact | Amanda Levy, LCSW | Therapist in Jackson, NJ">
  <meta property="og:description" content="Contact Amanda Levy, LCSW for a free 15-minute consultation. Located in Jackson, NJ. Phone, email, and online contact form available.">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">

  <!-- Canonical -->
  <link rel="canonical" href="https://amandalevylcsw.com/contact.html">
  <meta property="og:url" content="https://amandalevylcsw.com/contact.html">
  <meta property="og:image" content="https://amandalevylcsw.com/img/headshot.jpeg">
  <meta property="og:image:width" content="384">
  <meta property="og:image:height" content="384">
  <meta property="og:image:alt" content="Amanda Levy, LCSW — Therapist in Jackson, NJ">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Contact | Amanda Levy, LCSW | Therapist in Jackson, NJ">
  <meta name="twitter:description" content="Contact Amanda Levy, LCSW for a free 15-minute consultation. Located in Jackson, NJ. Phone, email, and online contact form available.">
  <meta name="twitter:image" content="https://amandalevylcsw.com/img/headshot.jpeg">
{% endblock %}

{% block content %}
  <main id="main-content">

    <!-- ========== CONTACT SECTION ========== -->
    <section id="contact" class="pt-24 py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-sage-900 mb-4">Get in Touch</h2>
          <div class="w-16 h-1 bg-sage-400 mx-auto rounded-full mb-6"></div>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">Ready to take the first step? Reach out for a free 15-minute consultation or to schedule your first appointment.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
          <!-- Contact Info -->
          <div>
            <div class="space-y-6 mb-8">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sage-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-sage-800">Phone</h3>
                  <a href="tel:9735174062" class="text-lg text-sage-600 hover:text-sage-700 font-medium">(973) 517-4062</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sage-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-sage-800">Email</h3>
                  <a href="mailto:amandalevylcsw@gmail.com" class="text-sage-600 hover:text-sage-700 font-medium">amandalevylcsw@gmail.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sage-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-sage-800">Location</h3>
                  <p class="text-gray-600">Jackson, NJ 08527</p>
                  <p class="text-sm text-gray-500">In-Person &amp; Telehealth (NJ &amp; NY)</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sage-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-sage-800">Hours</h3>
                  <p class="text-gray-600">Sunday &ndash; Thursday</p>
                  <p class="text-sm text-gray-500">Daytime &amp; Evening Appointments</p>
                </div>
              </div>
            </div>

            <!-- Google Maps Embed -->
            <div class="rounded-2xl overflow-hidden border border-sage-200 mb-8">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d48636.35316089!2d-74.39!3d40.1!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c16e6b5ada1b7d%3A0x7b1f44e1f2afabd9!2sJackson%2C%20NJ%2008527!5e0!3m2!1sen!2sus!4v1"
                width="100%"
                height="200"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Amanda Levy, LCSW — Jackson, NJ area"
              ></iframe>
            </div>

            <!-- CTA -->
            <div class="bg-sage-50 rounded-2xl p-6">
              <h3 class="font-serif text-lg font-semibold text-sage-800 mb-2">Free 15-Minute Consultation</h3>
              <p class="text-sm text-gray-600 mb-4">Not sure if therapy is right for you? Let's talk. Call for a free, no-obligation phone consultation.</p>
              <a href="tel:9735174062" class="inline-flex items-center gap-2 bg-sage-600 hover:bg-sage-700 text-white font-medium px-6 py-3 rounded-full transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Call (973) 517-4062
              </a>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <form id="contact-form" action="https://formspree.io/f/xpqjoarb" method="POST" class="bg-cream-50 rounded-2xl p-8 border border-cream-300">
              <h3 class="font-serif text-xl font-semibold text-sage-800 mb-6">Send a Message</h3>

              <div class="space-y-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Name <span class="text-red-400">*</span></label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:border-sage-400 focus:ring-2 focus:ring-sage-200 outline-none transition-all text-gray-700"
                    placeholder="Your full name"
                  >
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email <span class="text-red-400">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:border-sage-400 focus:ring-2 focus:ring-sage-200 outline-none transition-all text-gray-700"
                    placeholder="your@email.com"
                  >
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone <span class="text-gray-400 font-normal">(optional)</span></label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:border-sage-400 focus:ring-2 focus:ring-sage-200 outline-none transition-all text-gray-700"
                    placeholder="(555) 123-4567"
                  >
                </div>
                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-red-400">*</span></label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="5"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white focus:border-sage-400 focus:ring-2 focus:ring-sage-200 outline-none transition-all text-gray-700 resize-vertical"
                    placeholder="How can I help you?"
                  ></textarea>
                </div>
              </div>

              <!-- Honeypot for spam bots -->
              <input type="text" name="_gotcha" style="display:none">

              <p class="text-xs text-gray-400 mt-4 mb-5">
                <svg class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                Please do not include sensitive health information in this form.
              </p>

              <button
                type="submit"
                id="form-submit-btn"
                class="w-full bg-sage-600 hover:bg-sage-700 text-white font-semibold py-3.5 rounded-full transition-colors text-lg"
              >
                Send Message
              </button>

              <!-- Success Message -->
              <div id="form-success" class="hidden mt-4 p-4 bg-sage-50 border border-sage-200 rounded-xl text-center">
                <svg class="w-8 h-8 text-sage-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sage-700 font-medium">Message sent! Amanda will get back to you soon.</p>
              </div>

              <!-- Error Message -->
              <div id="form-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-center">
                <p class="text-red-600 font-medium">Something went wrong. Please try calling <a href="tel:9735174062" class="underline">(973) 517-4062</a> instead.</p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>
{% endblock %}
