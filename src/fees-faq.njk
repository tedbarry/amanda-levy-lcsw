{% extends "base.njk" %}

{% block title %}Fees, Insurance &amp; FAQ | Amanda Levy, LCSW{% endblock %}

{% block meta %}
  <meta name="description" content="Session fees, insurance information, and frequently asked questions about therapy with Amanda Levy, LCSW. Verify your insurance coverage and take a self-assessment.">
  <meta name="robots" content="index, follow">

  <!-- Open Graph -->
  <meta property="og:title" content="Fees, Insurance & FAQ | Amanda Levy, LCSW">
  <meta property="og:description" content="Session fees, insurance information, and frequently asked questions about therapy with Amanda Levy, LCSW.">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">

  <!-- Canonical -->
  <link rel="canonical" href="https://amandalevylcsw.com/fees-faq.html">
  <meta property="og:url" content="https://amandalevylcsw.com/fees-faq.html">
  <meta property="og:image" content="https://amandalevylcsw.com/img/headshot.jpeg">
  <meta property="og:image:width" content="384">
  <meta property="og:image:height" content="384">
  <meta property="og:image:alt" content="Amanda Levy, LCSW — Therapist in Jackson, NJ">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Fees, Insurance & FAQ | Amanda Levy, LCSW">
  <meta name="twitter:description" content="Session fees, insurance information, and frequently asked questions about therapy with Amanda Levy, LCSW.">
  <meta name="twitter:image" content="https://amandalevylcsw.com/img/headshot.jpeg">

  <!-- Structured Data: FAQ -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are your office hours?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "I offer both daytime and evening appointments, Sunday through Thursday. I understand that everyone's schedule is different, so I work to find times that are convenient for you."
        }
      },
      {
        "@type": "Question",
        "name": "What can I expect during my first session?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your first session is all about getting comfortable. We will take the time to get to know each other, and I will listen to understand what brought you to therapy. Together, we will begin to identify the stressors and needs in your life, and start building a personalized plan that works for you. There is no pressure — we move at your pace."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer a free consultation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! I offer a free 15-minute phone consultation so you can ask questions, share what you are looking for, and see if we are a good fit. Call (973) 517-4062 or use the contact form to get started."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer telehealth sessions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, I offer secure telehealth (video) sessions for clients located in New Jersey and New York. Telehealth provides the same quality therapy from the comfort and privacy of your own home."
        }
      },
      {
        "@type": "Question",
        "name": "How often will we meet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Scheduling is flexible and based on your individual needs. Many clients start with weekly sessions and adjust frequency over time. We will work together to find a cadence that supports your progress and fits your life."
        }
      },
      {
        "@type": "Question",
        "name": "What if I have never been to therapy before?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "That is perfectly okay! Many of my clients are new to therapy. My approach is warm, non-judgmental, and collaborative. I will guide you through the process and make sure you feel comfortable every step of the way."
        }
      }
    ]
  }
  </script>
{% endblock %}

{% block content %}
  <main id="main-content">

    <!-- ========== FEES & INSURANCE SECTION ========== -->
    <section id="fees" class="pt-24 py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-sage-900 mb-4">Fees &amp; Insurance</h2>
          <div class="w-16 h-1 bg-sage-400 mx-auto rounded-full mb-6"></div>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">Transparent pricing with no surprises. I believe quality therapy should be accessible.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-12">
          <!-- Session Fees -->
          <div class="bg-cream-50 rounded-2xl p-8 border border-cream-300">
            <h3 class="font-serif text-xl font-semibold text-sage-800 mb-6">Session Fees</h3>
            <div class="space-y-6">
              <div class="flex items-center justify-between pb-4 border-b border-cream-300">
                <div>
                  <p class="font-medium text-gray-800">Individual Session</p>
                  <p class="text-sm text-gray-500">50 minutes</p>
                </div>
                <p class="text-2xl font-serif font-bold text-sage-700">$200</p>
              </div>
              <div class="flex items-center justify-between pb-4 border-b border-cream-300">
                <div>
                  <p class="font-medium text-gray-800">Couple Session</p>
                  <p class="text-sm text-gray-500">50 minutes</p>
                </div>
                <p class="text-2xl font-serif font-bold text-sage-700">$250</p>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium text-gray-800">Initial Consultation</p>
                  <p class="text-sm text-gray-500">15 minutes by phone</p>
                </div>
                <p class="text-2xl font-serif font-bold text-sage-600">Free</p>
              </div>
            </div>
            <div class="mt-6 p-4 bg-sage-50 rounded-xl">
              <p class="text-sm text-sage-700">
                <strong>Sliding scale available.</strong> If cost is a concern, please don't hesitate to reach out. We can discuss options.
              </p>
            </div>
            <div class="mt-4">
              <p class="text-sm text-gray-500"><strong>Payment methods:</strong> Cash, Check</p>
            </div>
          </div>

          <!-- Insurance -->
          <div class="bg-cream-50 rounded-2xl p-8 border border-cream-300">
            <h3 class="font-serif text-xl font-semibold text-sage-800 mb-6">Insurance Accepted</h3>
            <div class="space-y-4 mb-8">
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg">
                <svg class="w-6 h-6 text-sage-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="font-medium text-gray-700">Aetna</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg">
                <svg class="w-6 h-6 text-sage-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="font-medium text-gray-700">Cigna</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg">
                <svg class="w-6 h-6 text-sage-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="font-medium text-gray-700">Medicare</span>
              </div>
            </div>

            <div class="bg-sky-50 rounded-xl p-5 border border-sky-200">
              <h4 class="font-semibold text-sage-800 mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-sky-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                Out-of-Network Benefits
              </h4>
              <p class="text-sm text-gray-600 leading-relaxed">
                Even if your insurance plan is not listed above, you may still have <strong>out-of-network benefits</strong> that can help cover the cost of therapy. This means your insurance company may reimburse you for a portion of each session after you pay upfront. I can provide you with a superbill (a detailed receipt) that you can submit to your insurance for reimbursement. Contact your insurance company and ask about your out-of-network mental health benefits to find out what you may be eligible for.
              </p>
            </div>
          </div>
        </div>
        <!-- Insurance Verification Helper -->
        <div class="mt-12 bg-sky-50 rounded-2xl p-8 border border-sky-200 max-w-4xl mx-auto">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-sky-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-serif text-xl font-semibold text-sage-800 mb-1">Not Sure If Your Insurance Covers Therapy?</h3>
              <p class="text-gray-600 text-sm">Call the number on the back of your insurance card and ask these questions:</p>
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="insurance-step">
              <div class="insurance-step-num">1</div>
              <p class="text-sm text-gray-700">&ldquo;Do I have <strong>out-of-network mental health benefits</strong>?&rdquo;</p>
            </div>
            <div class="insurance-step">
              <div class="insurance-step-num">2</div>
              <p class="text-sm text-gray-700">&ldquo;What is my <strong>deductible</strong> for outpatient mental health?&rdquo;</p>
            </div>
            <div class="insurance-step">
              <div class="insurance-step-num">3</div>
              <p class="text-sm text-gray-700">&ldquo;What <strong>percentage</strong> do you reimburse after the deductible?&rdquo;</p>
            </div>
            <div class="insurance-step">
              <div class="insurance-step-num">4</div>
              <p class="text-sm text-gray-700">&ldquo;Is there a <strong>limit on the number of sessions</strong> per year?&rdquo;</p>
            </div>
          </div>
          <p class="text-xs text-gray-500 mt-4">Tip: Ask for a reference number for the call. Amanda can provide a superbill (detailed receipt) for you to submit for reimbursement.</p>
        </div>

      </div>
    </section>

    <!-- ========== FAQ SECTION ========== -->
    <section id="faq" class="py-16 md:py-24 bg-sage-50/50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-sage-900 mb-4">Frequently Asked Questions</h2>
          <div class="w-16 h-1 bg-sage-400 mx-auto rounded-full"></div>
        </div>

        <div class="space-y-4">
          <!-- FAQ 1 -->
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span class="font-medium text-sage-800 text-left">What are your office hours?</span>
              <svg class="faq-chevron w-5 h-5 text-sage-500 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer">
              <p>I offer both daytime and evening appointments, Sunday through Thursday. I understand that everyone's schedule is different, so I work to find times that are convenient for you.</p>
            </div>
          </div>

          <!-- FAQ 2 -->
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span class="font-medium text-sage-800 text-left">What can I expect during my first session?</span>
              <svg class="faq-chevron w-5 h-5 text-sage-500 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer">
              <p>Your first session is all about getting comfortable. We will take the time to get to know each other, and I will listen to understand what brought you to therapy. Together, we will begin to identify the stressors and needs in your life, and start building a personalized plan that works for you. There is no pressure &mdash; we move at your pace.</p>
            </div>
          </div>

          <!-- FAQ 3 -->
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span class="font-medium text-sage-800 text-left">Do you offer a free consultation?</span>
              <svg class="faq-chevron w-5 h-5 text-sage-500 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer">
              <p>Yes! I offer a <strong>free 15-minute phone consultation</strong> so you can ask questions, share what you are looking for, and see if we are a good fit. Finding the right therapist is important, and I want you to feel confident in your decision. Call <a href="tel:9735174062" class="text-sage-600 font-medium hover:underline">(973) 517-4062</a> or use the <a href="/contact.html" class="text-sage-600 font-medium hover:underline">contact form</a> to get started.</p>
            </div>
          </div>

          <!-- FAQ 4 -->
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span class="font-medium text-sage-800 text-left">Do you offer telehealth sessions?</span>
              <svg class="faq-chevron w-5 h-5 text-sage-500 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer">
              <p>Yes, I offer secure telehealth (video) sessions for clients located in <strong>New Jersey</strong> and <strong>New York</strong>. Telehealth provides the same quality therapy from the comfort and privacy of your own home. It is a great option for clients with busy schedules, mobility concerns, or those who simply prefer the convenience of virtual sessions.</p>
            </div>
          </div>

          <!-- FAQ 5 -->
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span class="font-medium text-sage-800 text-left">How often will we meet?</span>
              <svg class="faq-chevron w-5 h-5 text-sage-500 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer">
              <p>Scheduling is flexible and based on your individual needs. Many clients start with weekly sessions and adjust frequency over time. We will work together to find a cadence that supports your progress and fits your life.</p>
            </div>
          </div>

          <!-- FAQ 6 -->
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span class="font-medium text-sage-800 text-left">What if I have never been to therapy before?</span>
              <svg class="faq-chevron w-5 h-5 text-sage-500 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer">
              <p>That is perfectly okay! Many of my clients are new to therapy. My approach is warm, non-judgmental, and collaborative. I will guide you through the process and make sure you feel comfortable every step of the way. Reaching out is the hardest part &mdash; and you have already taken that step by being here.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== IS THERAPY RIGHT FOR ME? SELF-CHECK ========== -->
    <section id="self-check" class="py-16 md:py-24 bg-white">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-sage-900 mb-4">Is Therapy Right for Me?</h2>
          <div class="w-16 h-1 bg-sage-400 mx-auto rounded-full mb-6"></div>
          <p class="text-lg text-gray-600">A quick, private self-reflection. Nothing is recorded or saved.</p>
        </div>

        <div id="self-check-widget" class="bg-cream-50 rounded-2xl p-8 border border-cream-300">
          <!-- Questions Container -->
          <div id="sc-questions">
            <div class="sc-question active" data-q="0">
              <p class="text-lg text-sage-800 font-medium mb-6">Do you often feel overwhelmed by daily responsibilities or emotions?</p>
              <div class="flex gap-4 justify-center">
                <button class="sc-btn sc-yes" data-answer="yes">Yes</button>
                <button class="sc-btn sc-no" data-answer="no">Not really</button>
              </div>
            </div>
            <div class="sc-question" data-q="1">
              <p class="text-lg text-sage-800 font-medium mb-6">Are relationships in your life causing you stress or frustration?</p>
              <div class="flex gap-4 justify-center">
                <button class="sc-btn sc-yes" data-answer="yes">Yes</button>
                <button class="sc-btn sc-no" data-answer="no">Not really</button>
              </div>
            </div>
            <div class="sc-question" data-q="2">
              <p class="text-lg text-sage-800 font-medium mb-6">Have you been having trouble sleeping, concentrating, or enjoying things you used to?</p>
              <div class="flex gap-4 justify-center">
                <button class="sc-btn sc-yes" data-answer="yes">Yes</button>
                <button class="sc-btn sc-no" data-answer="no">Not really</button>
              </div>
            </div>
            <div class="sc-question" data-q="3">
              <p class="text-lg text-sage-800 font-medium mb-6">Do you wish you had someone to talk to who really understands?</p>
              <div class="flex gap-4 justify-center">
                <button class="sc-btn sc-yes" data-answer="yes">Yes</button>
                <button class="sc-btn sc-no" data-answer="no">Not really</button>
              </div>
            </div>
            <div class="sc-question" data-q="4">
              <p class="text-lg text-sage-800 font-medium mb-6">Are you going through a major life change or transition?</p>
              <div class="flex gap-4 justify-center">
                <button class="sc-btn sc-yes" data-answer="yes">Yes</button>
                <button class="sc-btn sc-no" data-answer="no">Not really</button>
              </div>
            </div>
          </div>

          <!-- Progress Bar -->
          <div class="mt-6 mb-2">
            <div class="w-full bg-sage-100 rounded-full h-2">
              <div id="sc-progress" class="bg-sage-400 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-2 text-center" id="sc-progress-text">Question 1 of 5</p>
          </div>

          <!-- Result (hidden initially) -->
          <div id="sc-result" class="hidden text-center">
            <div class="w-16 h-16 bg-sage-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </div>
            <p id="sc-result-text" class="text-lg text-sage-800 font-medium leading-relaxed mb-6"></p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="tel:9735174062" class="inline-flex items-center justify-center gap-2 bg-sage-600 hover:bg-sage-700 text-white font-semibold px-6 py-3 rounded-full transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Call for Free Consultation
              </a>
              <button id="sc-restart" class="inline-flex items-center justify-center gap-2 border-2 border-sage-300 text-sage-700 hover:bg-sage-50 font-medium px-6 py-3 rounded-full transition-colors">
                Start Over
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
{% endblock %}
